{
  "config": {
    "step": {
      "user": {
        "title": "EcoFlow Cloud – Setup",
        "description": "Add your EcoFlow device. **Auto-detect** (recommended) automatically chooses the correct API based on your serial number.",
        "data": {
          "device_sn":  "Device Serial Number",
          "auth_mode":  "Connection Method"
        },
        "data_description": {
          "device_sn": "Printed on the device label or visible in the EcoFlow app under Device Info",
          "auth_mode": "Auto-detect picks App Login for Delta 3 / newer devices, Developer API for older ones"
        }
      },
      "public_creds": {
        "title": "EcoFlow Cloud – Developer API",
        "description": "{hint}",
        "data": {
          "access_key": "Access Key",
          "secret_key": "Secret Key"
        }
      },
      "private_creds": {
        "title": "EcoFlow Cloud – App Login",
        "description": "{hint}",
        "data": {
          "email":    "EcoFlow Account Email",
          "password": "EcoFlow Account Password"
        }
      },
      "developer_creds": {
        "title": "EcoFlow Cloud – Developer API (Optional)",
        "description": "{hint}",
        "data": {
          "dev_access_key": "Developer Access Key (optional)",
          "dev_secret_key": "Developer Secret Key (optional)"
        },
        "data_description": {
          "dev_access_key": "Enables switch and number control via REST API. Leave empty to skip.",
          "dev_secret_key": "Required if Access Key is provided."
        }
      },
      "test": {
        "title": "EcoFlow Cloud – Connection Test",
        "description": "{eu}\n{us}\n{glob}\n\n{hint}"
      }
    },
    "error": {
      "cannot_connect": "Cannot connect – check your credentials.",
      "unknown": "Unexpected error. Check the Home Assistant logs."
    },
    "abort": {
      "already_configured": "This device is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "EcoFlow Cloud – Settings ({mode})",
        "description": "Current API server: {current_host}",
        "data": {
          "access_key": "Access Key",
          "secret_key": "Secret Key",
          "email":      "EcoFlow Account Email",
          "password":   "EcoFlow Account Password",
          "device_sn":  "Device Serial Number",
          "api_host":   "API Server",
          "dev_access_key": "Developer Access Key (optional, for REST control)",
          "dev_secret_key": "Developer Secret Key"
        }
      }
    },
    "error": {
      "cannot_connect": "Cannot connect with these credentials."
    }
  }
}
